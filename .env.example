# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:<password>@127.0.0.1:5432/mindup
# or Supabase:
# DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# --- Auth: Clerk JWT ---
# Students authenticate with: Authorization: Bearer <clerk_jwt>
# Get these from Clerk dashboard -> API Keys -> Advanced
CLERK_JWKS_URL=https://<your-clerk-frontend-api>/.well-known/jwks.json
CLERK_ISSUER=https://<your-clerk-frontend-api>

# --- Clerk Webhook ---
CLERK_WEBHOOK_SECRET=whsec_...

# --- Storage ---
# mock: returns fake signed URLs (no Supabase needed)
# supabase: uses Supabase Storage signing API
STORAGE_MODE=mock
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=mindup-resources
SUPABASE_SIGNED_URL_EXPIRES_IN=3600

# --- Admin API key (admin team member's system) ---
ADMIN_API_KEY=change-me

# --- CORS ---
CORS_ALLOW_ORIGINS=*
