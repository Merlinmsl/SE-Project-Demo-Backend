                "key": "X-Admin-Api-Key",
                "value": "{{adminApiKey}}"
              }
            ],
            "url": "{{baseUrl}}/api/v1/admin/stats/student-count"
          }
        }
      ]
    },
    {
      "name": "❌ Auth Edge Cases",
      "item": [
        {
          "name": "No token → expect 401",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/me/profile"
          }
        },
        {
          "name": "Bad token → expect 401",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "this.is.not.a.real.token",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/me/profile"
          }
        },
        {
          "name": "Onboarding — bad district_id → expect 400",
          "request": {
