              "raw": "{\n  \"full_name\": \"Test\",\n  \"username\": \"edge_case_bad_district\",\n  \"grade_id\": 1,\n  \"province_id\": 1,\n  \"district_id\": 99999,\n  \"avatar_key\": \"avatar_1\",\n  \"subject_ids\": [1]\n}"
